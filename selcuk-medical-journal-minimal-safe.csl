<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" version="1.0" class="in-text" default-locale="en-US" page-range-format="minimal-two">
  <info>
    <title>Selcuk Medical Journal</title>
    <title-short>Selcuk Med J</title-short>
    <id>http://www.zotero.org/styles/selcuk-medical-journal</id>
    <link href="http://www.zotero.org/styles/selcuk-medical-journal" rel="self"/>
    <author>
      <name>OpenAI</name>
    </author>
    <category citation-format="numeric"/>
    <category field="medicine"/>
    <summary>Custom numeric style for Selcuk Medical Journal.</summary>
    <updated>2026-04-05T09:45:00+03:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/">This work is licensed under a Creative Commons Attribution-ShareAlike 3.0 License</rights>
  </info>

  <macro name="author">
    <names variable="author" delimiter=", " et-al-min="4" et-al-use-first="3">
      <name form="long" initialize-with="" delimiter=", " and="text"/>
      <et-al term="et-al"/>
      <substitute>
        <names variable="editor"/>
      </substitute>
    </names>
  </macro>

  <macro name="editor">
    <names variable="editor" delimiter=", " et-al-min="4" et-al-use-first="3">
      <name form="long" initialize-with="" delimiter=", " and="text"/>
      <et-al term="et-al"/>
      <label form="short" prefix=", "/>
    </names>
  </macro>

  <macro name="title">
    <text variable="title"/>
  </macro>

  <macro name="journal">
    <text variable="container-title" form="short"/>
  </macro>

  <macro name="year">
    <date variable="issued">
      <date-part name="year"/>
    </date>
  </macro>

  <macro name="volume-issue">
    <group delimiter="">
      <text variable="volume"/>
      <group prefix="(" suffix=")">
        <text variable="issue"/>
      </group>
    </group>
  </macro>

  <macro name="edition">
    <choose>
      <if is-numeric="edition">
        <number variable="edition" form="ordinal"/>
        <text term="edition" form="short" prefix=" " suffix="."/>
      </if>
      <else-if variable="edition">
        <text variable="edition" suffix="."/>
      </else-if>
    </choose>
  </macro>

  <macro name="publisher">
    <group delimiter=": ">
      <text variable="publisher-place"/>
      <text variable="publisher"/>
    </group>
  </macro>

  <macro name="access">
    <group delimiter=" ">
      <text value="Accessed"/>
      <date variable="accessed">
        <date-part name="day"/>
        <date-part name="month" form="short"/>
        <date-part name="year"/>
      </date>
    </group>
  </macro>

  <macro name="doi">
    <choose>
      <if variable="DOI">
        <text variable="DOI" prefix=". doi: "/>
      </if>
    </choose>
  </macro>

  <citation>
    <layout prefix="(" suffix=")" delimiter=", ">
      <text variable="citation-number"/>
    </layout>
  </citation>

  <bibliography>
    <sort>
      <key variable="citation-number"/>
    </sort>
    <layout suffix=".">
      <text variable="citation-number" suffix=" "/>
      <choose>
        <if type="article-journal">
          <text macro="author" suffix=". "/>
          <text macro="title" suffix=". "/>
          <text macro="journal" suffix=". "/>
          <text macro="year" suffix=";"/>
          <text macro="volume-issue" suffix=":"/>
          <text variable="page"/>
          <text macro="doi"/>
        </if>

        <else-if type="book">
          <text macro="author" suffix=". "/>
          <text macro="title" suffix=". "/>
          <text macro="edition" suffix=" "/>
          <text macro="publisher" suffix=", "/>
          <text macro="year"/>
        </else-if>

        <else-if type="chapter">
          <text macro="author" suffix=". "/>
          <text macro="title" suffix=". "/>
          <text value="In: " />
          <text macro="editor" suffix=". "/>
          <text variable="container-title" suffix=". "/>
          <text macro="edition" suffix=" "/>
          <text macro="publisher" suffix=", "/>
          <text macro="year" suffix=":"/>
          <text variable="page"/>
        </else-if>

        <else-if type="thesis">
          <text macro="author" suffix=". "/>
          <text macro="title" suffix=". "/>
          <text value="PhD thesis. "/>
          <text variable="publisher" suffix=", "/>
          <text macro="year"/>
        </else-if>

        <else-if type="webpage">
          <text macro="author" suffix=". "/>
          <text macro="title" suffix=". "/>
          <text variable="container-title" suffix=". "/>
          <text variable="URL" suffix=". "/>
          <text macro="access"/>
        </else-if>

        <else>
          <text macro="author" suffix=". "/>
          <text macro="title" suffix=". "/>
          <text variable="container-title" suffix=". "/>
          <text macro="year"/>
        </else>
      </choose>
    </layout>
  </bibliography>
</style>
